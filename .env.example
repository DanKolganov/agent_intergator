# Postgres database connection (required)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@db:5432/agentdb

# Session secret for express-session (required)
SESSION_SECRET=replace-with-a-very-strong-secret

# Replit OIDC client id (required if you use Replit Auth)
REPL_ID=

# Optional: override OIDC issuer url (defaults to https://replit.com/oidc)
ISSUER_URL=https://replit.com/oidc

# OpenAI integration
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Port the app listens on (default 5000)
PORT=5000
